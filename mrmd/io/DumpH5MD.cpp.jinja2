void DumpH5MD::dump(const std::string& /*filename*/,
                            const data::Subdomain& /*subdomain*/,
                            const data::Atoms& /*atoms*/)
{
    MRMD_HOST_CHECK(false, "HDF5 Support not available!");
    exit(EXIT_FAILURE);
}
#endif

