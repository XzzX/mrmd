	issn = {1434-6036},
	url = {https://doi.org/10.1140/epjb/s10051-021-00193-w},
	doi = {10.1140/epjb/s10051-021-00193-w},
	abstract = {We provide an overview of the Adaptive Resolution Simulation method (AdResS) based on discussing its basic principles and presenting its current numerical and theoretical developments. Examples of applications to systems of interest to soft matter, chemical physics, and condensed matter illustrate the method’s advantages and limitations in its practical use and thus settle the challenge for further future numerical and theoretical developments.},
	language = {en},
	number = {9},
	urldate = {2026-03-02},
	journal = {The European Physical Journal B},
	author = {Cortes-Huerto, Robinson and Praprotnik, Matej and Kremer, Kurt and Delle Site, Luigi},
	month = sep,
	year = {2021},
	pages = {189},
	file = {Full Text PDF:/srv/public/julianhille/Literature/storage/X38QZVFM/Cortes-Huerto et al. - 2021 - From adaptive resolution to molecular dynamics of open systems.pdf:application/pdf},
}

@article{klein_nonequilibrium_2021,
	title = {Nonequilibrium {Induced} by {Reservoirs}: {Physico}-{Mathematical} {Models} and {Numerical} {Tests}},
	volume = {4},
	copyright = {© 2021 The Authors. Advanced Theory and Simulations published by Wiley-VCH GmbH},
	issn = {2513-0390},
	shorttitle = {Nonequilibrium {Induced} by {Reservoirs}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/adts.202100071},
	doi = {10.1002/adts.202100071},
	abstract = {In a recently proposed computational model of open molecular systems out of equilibrium the action of different reservoirs enters as a linear sum into the Liouville-type evolution equations for the open system's statistics. The linearity of the coupling is common to different mathematical models of open systems and essentially relies on neglecting the feedback of the system onto the reservoir due to their interaction. In this paper, the range of applicability of the computational model is tested with a linear coupling to two different reservoirs, which induces a nonequilibrium situation. To this end, the density profiles of Lennard–Jones liquids in large thermal gradients are studied using nonequilibrium molecular dynamics simulations with open boundaries. The authors put in perspective the formulation of an extension of the mathematical model that can account for nonlinear effects.},
	language = {en},
	number = {7},
	urldate = {2023-07-19},
	journal = {Advanced Theory and Simulations},
	author = {Klein, Rupert and Ebrahimi Viand, Roya and Höfling, Felix and Delle Site, Luigi},
	year = {2021},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/adts.202100071},
	keywords = {adaptive resolution method, mathematical models, nonequilibrium molecular dynamics, numerical tests, open systems},
	pages = {2100071},
	file = {Full Text PDF:/srv/public/julianhille/Literature/storage/IU4Z7NQY/Klein et al. - 2021 - Nonequilibrium Induced by Reservoirs Physico-Math.pdf:application/pdf;Snapshot:/srv/public/julianhille/Literature/storage/5WDC4BKT/adts.html:text/html},
}

@article{gholami_simulation_2022,
	title = {Simulation of a {Particle} {Domain} in a {Continuum}, {Fluctuating} {Hydrodynamics} {Reservoir}},
	volume = {129},
	url = {https://link.aps.org/doi/10.1103/PhysRevLett.129.230603},
	doi = {10.1103/PhysRevLett.129.230603},
	abstract = {In molecular simulation and fluid mechanics, the coupling of a particle domain with a continuum representation of its embedding environment is an ongoing challenge. In this Letter, we show a novel approach where the latest version of the adaptive resolution scheme (AdResS), with noninteracting tracers as particles’ reservoir, is combined with a fluctuating hydrodynamics (FHD) solver. The resulting algorithm, supported by a solid mathematical model, allows for a physically consistent exchange of matter and energy between the particle domain and its fluctuating continuum reservoir. Numerical tests are performed to show the validity of the algorithm. Differently from previous algorithms of the same kind, the current approach allows for simulations where, in addition to density fluctuations, also thermal fluctuations can be accounted for, thus large complex molecular systems, as, for example, hydrated biological membranes in a thermal field, can now be efficiently treated.},
	number = {23},
	urldate = {2023-07-19},
	journal = {Physical Review Letters},
	publisher = {American Physical Society},
	author = {Gholami, Abbas and Klein, Rupert and Delle Site, Luigi},
	month = nov,
	year = {2022},
	pages = {230603},
	file = {APS Snapshot:/srv/public/julianhille/Literature/storage/P62DSRFG/PhysRevLett.129.html:text/html;Full Text PDF:/srv/public/julianhille/Literature/storage/3NE5CXT8/Gholami et al. - 2022 - Simulation of a Particle Domain in a Continuum, Fl.pdf:application/pdf;SM.pdf:/srv/public/julianhille/Literature/storage/X23QS6TI/SM.pdf:application/pdf},
}

